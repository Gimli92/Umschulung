class Fachbuch(Books):

    def __init__(self, name, isbn, author, verliehen, fach):

        super().__init__(name, isbn, author, verliehen)
        self.__fach = fach

    def __str__(self):

        return super().__str__() + f", Fach: {self.__fach}"


